%% M61 erlang-rebar3/hello-binary fixture: rebar3 project manifest.
%%
%% Erlang term syntax (sexp-like). Declares:
%%   * ``erl_opts`` — compiler options for ``rebar3 compile``.
%%   * ``deps`` — external Hex dependencies. Empty for the fixture so
%%     the build needs no network access / pre-warmed Hex cache.
%%   * ``escript_*`` — escriptize stanza pointing the produced escript
%%     at the ``hello`` OTP application's ``main/1`` callback.
%%
%% ``rebar3 escriptize`` reads these and produces
%% ``_build/default/bin/hello`` plus (on Windows) the sibling
%% ``_build/default/bin/hello.cmd`` launcher.

{erl_opts, [debug_info]}.
{deps, []}.

{escript_name, hello}.
{escript_main_app, hello}.
{escript_incl_apps, [hello]}.
{escript_emu_args, "%%! -escript main hello\n"}.
