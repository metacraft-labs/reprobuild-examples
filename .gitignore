# Build output that may appear inside an example dir during local
# verification. Per-language conventions vary; this is a superset.
build/
dist/
target/
bin/
obj/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.obj
.repro/
.reprobuild/
node_modules/
__pycache__/
*.pyc
.venv/
venv/
nimcache/
.nimcache/
*.gem
.bundle/
Gemfile.lock
package-lock.json
yarn.lock
pnpm-lock.yaml
Cargo.lock
# M6 build-rs fixture: the crude action invokes
# ``cargo build --release --locked --offline`` so the lockfile MUST be
# committed for reproducibility. Without this negation rule the global
# ``Cargo.lock`` ignore above would force the fixture maintainer to
# ``git add -f`` on every lockfile bump, which silently rots.
!rust/binary-with-build-rs/Cargo.lock
.gradle/
.idea/
.vscode/
